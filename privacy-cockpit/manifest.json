{
  "manifest_version": 3,
  "name": "Adworth Privacy Cockpit",
  "version": "1.1.0",
  "description": "Cryptographically sign and submit your advertising consent with on-device Ed25519 keys. Your private key never leaves your device.",
  "permissions": [
    "storage",
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "https://ads.google.com/*",
    "https://business.facebook.com/*",
    "https://adworth.app/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    },
    "default_title": "Adworth Privacy Cockpit"
  }
}
