{
  "manifest_version": 3,
  "name": "Adworth Privacy Cockpit",
  "version": "1.0.0",
  "description": "Extract and protect your marketing data with Ed25519 cryptography",

  "permissions": [
    "storage",
    "activeTab"
  ],

  "host_permissions": [
    "https://ads.google.com/*",
    "https://business.facebook.com/*",
    "https://adworth.app/demo/*"
  ],

  "background": {
    "service_worker": "background.js"
  },

  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    },
    "default_title": "Adworth Privacy Cockpit"
  },

  "content_scripts": [
    {
      "matches": [
        "https://ads.google.com/*",
        "https://business.facebook.com/*",
        "https://adworth.app/demo/*"
      ],
      "js": ["content-script.js"],
      "run_at": "document_start"
    }
  ]
}
